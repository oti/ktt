{
  "name": "ktt",
  "version": "3.7.1",
  "private": true,
  "description": "「今朝はTKGを食べました」を一覧できるウェブサイト",
  "license": "CC BY-NC 4.0",
  "author": "oti",
  "scripts": {
    "clean": "rm -rf dist && mkdir dist",
    "cp:favicon": "cp -r src/favicon.ico dist/favicon.ico",
    "cp:image": "cp -rv src/image/ dist/image/",
    "cp:style": "cp -r src/style/ dist/style/",
    "prebuild": "npm run clean && npm run cp:favicon && npm run cp:style && npm run cp:image",
    "build": "pug src -o dist -O .pugrc -P",
    "postbuild": "rm -rf dist/pug/",
    "start": "npm run build && cd dist && python3 -m http.server 3000",
    "update:data": "node generator/data.mjs",
    "update:photo": "node generator/photo.mjs"
  },
  "devDependencies": {
    "pug-cli": "^1.0.0-alpha6",
    "sharp": "^0.35.1"
  },
  "name_jp": "今朝はTKGを食べました。"
}
